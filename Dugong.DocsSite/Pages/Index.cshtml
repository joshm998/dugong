@using StaticSiteGen
@inherits StaticPage<StaticSiteGen.SiteModel>

<head>
    @{ await IncludeAsync("Components/Head.cshtml", Model); }
</head>

@{ await IncludeAsync("Components/Header.cshtml", Model); }

<section class="text-gray-600 body-font">
    <div class="container mx-auto flex px-5 py-24 items-center justify-center flex-col">
        <div class="text-center lg:w-2/3 w-full">
            <h1 class="title-font sm:text-4xl text-4xl mb-4 font-medium text-gray-900">Build it the way you want</h1>
            <p class="mb-8 text-2xl leading-relaxed">@Model.SiteTitle allows you to create websites fast using the templating engine and content sources you are used to.</p>
            <div class="flex justify-center">
                <button class="inline-flex text-white bg-indigo-500 border-0 py-2 px-6 focus:outline-none hover:bg-indigo-600 rounded text-lg">Get Started</button>
            </div>
        </div>
    </div>
</section>